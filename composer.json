{
	"name": "hintik/nette-base-project",
	"description": "Base Nette Project",
	"keywords": ["nette", "php", "skeleton", "project"],
	"type": "project",
	"license": "MIT",
	"authors": [
		{
			"name": "Jan Hinterholzinger",
			"email": "jan@hinterholzinger.cz",
			"homepage": "https://github.com/hintik-dev"
		}
	],
	"homepage": "https://github.com/hintik-dev/nette-base-project",
	"support": {
		"issues": "https://github.com/hintik-dev/nette-base-project/issues",
		"source": "https://github.com/hintik-dev/nette-base-project"
	},
	"require": {
		"php": ">= 8.5",
		"nette/application": "^3.2.9",
		"nette/assets": "^1.0.5",
		"nette/bootstrap": "^3.2.7",
		"nette/caching": "^3.4",
		"nette/database": "^3.2",
		"nette/di": "^3.2",
		"nette/forms": "^3.2",
		"nette/http": "^3.3",
		"nette/mail": "^4.0",
		"nette/robot-loader": "^4.1",
		"nette/security": "^3.2",
		"nette/utils": "^4.1",
		"latte/latte": "^3.1",
		"tracy/tracy": "^2.11",
		"robmorgan/phinx": "^0.16.10",
		"symfony/console": "^7.4"
	},
	"require-dev": {
		"nette/tester": "^2.6",
		"phpstan/phpstan-nette": "^2",
		"rector/rector": "^2.0",
		"slevomat/coding-standard": "^8.0",
		"squizlabs/php_codesniffer": "^3.0",
		"symfony/thanks": "^1"
	},
	"autoload": {
		"psr-4": {
			"App\\": "app"
		}
	},
	"scripts": {
        "all": [
          "Composer\\Config::disableProcessTimeout",
          "vendor/bin/phpstan analyse -c phpstan.neon --memory-limit=2048M -a vendor/squizlabs/php_codesniffer/autoload.php",
          "php -d 'disable_functions=\"\"' vendor/bin/phpcs --parallel=$(nproc --all) --standard=.phpcs.xml app/ tests/ -s --colors -p",
          "@latte-lint",
          "@neon-lint",
          "@rector"
        ],
        "all:fix": [
          "Composer\\Config::disableProcessTimeout",
          "php -d 'disable_functions=\"\"' vendor/bin/phpcbf --parallel=$(nproc --all) --standard=.phpcs.xml app/ tests/ -s --colors -p",
          "php bin/strict-types"
        ],
		"phpstan": "vendor/bin/phpstan analyse -c phpstan.neon --memory-limit=2048M -a vendor/squizlabs/php_codesniffer/autoload.php",
		"phpcs": "php -d 'disable_functions=\"\"' vendor/bin/phpcs --parallel=$(nproc --all) --standard=.phpcs.xml app/ tests/ -s --colors -p",
		"phpcs:fix": "php -d 'disable_functions=\"\"' vendor/bin/phpcbf --parallel=$(nproc --all) --standard=.phpcs.xml app/ tests/ -s --colors -p",
		"rector": "rector process app --dry-run",
		"rector:fix": "rector process app",
		"strict-types": "php bin/strict-types --dry-run",
		"strict-types:fix": "php bin/strict-types",
		"latte-lint": "php latte-lint",
		"neon-lint": "php vendor/bin/neon-lint config",
		"tester": "tester tests -s",
		"lint": [
			"@phpstan",
			"@phpcs",
			"@latte-lint",
			"@neon-lint",
			"@tester"
		]
	},
	"bin": ["bin/console"],
	"minimum-stability": "stable",
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true,
			"symfony/thanks": true
		}
	}
}
